  EXAMPLES_PASSWORD: "examples"
  SUPERSET_SECRET_KEY: "CHANGE_ME_TO_A_RANDOM_SECRET"
  ADMIN_PASSWORD: "admin"
  MAPBOX_API_KEY: "CHANGE_ME"
